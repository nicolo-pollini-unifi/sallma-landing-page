---
import "../styles/global.css";
import unifiLogo from "../assets/logo-unifi-dinfo.png";
import stlabLogo from "../assets/logo-stlab.png";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "SALLMA: A Software Architecture for LLM-Based Multi-Agent Systems",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body
		class="bg-gray-50 text-gray-900 font-sans antialiased selection:bg-indigo-500 selection:text-white"
	>
		<nav
			class="sticky top-0 z-50 w-full backdrop-blur-md bg-white/80 border-b border-gray-200"
		>
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between items-center h-16">
					<div class="shrink-0">
						<a href="/" class="flex items-center gap-2">
							<!-- Placeholder Logo -->
							<div
								class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center text-white font-bold"
							>
								S
							</div>
							<span
								class="font-bold text-xl tracking-tight text-gray-900"
								>SALLMA</span
							>
						</a>
					</div>
					<div class="hidden md:block">
						<div class="ml-10 flex items-baseline space-x-4">
							<a
								href="/"
								class="hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors"
								>Home</a
							>
							<a
								href="#features"
								class="hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors"
								>Features</a
							>
							<a
								href="/docs"
								class="hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors"
								>Documentation</a
							>
							<a
								href="/posts"
								class="hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors"
								>Blog</a
							>
							<a
								href="/publications"
								class="hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors"
								>Publications</a
							>
							<a
								href="/contributors"
								class="hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors"
								>Contributors</a
							>
							<!-- FIXME: repo is private -->
							<a
								href="https://github.com/STLab-UniFI/SALLMA"
								target="_blank"
								rel="noopener noreferrer"
								class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors"
								>GitHub</a
							>
						</div>
					</div>
					<!-- Mobile menu button -->
					<div class="-mr-2 flex md:hidden">
						<button
							type="button"
							class="bg-gray-50 inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
							aria-controls="mobile-menu"
							aria-expanded="false"
						>
							<span class="sr-only">Open main menu</span>
							<svg
								class="block h-6 w-6"
								xmlns="http://www.w3.org/2000/svg"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
								aria-hidden="true"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M4 6h16M4 12h16M4 18h16"></path>
							</svg>
						</button>
					</div>
				</div>
			</div>
			<!-- Mobile Menu (simple implementation, improved with JS later if needed) -->
			<div class="md:hidden hidden" id="mobile-menu">
				<div
					class="px-2 pt-2 pb-3 space-y-1 sm:px-3 bg-white border-b border-gray-200"
				>
					<a
						href="/"
						class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50"
						>Home</a
					>
					<a
						href="#features"
						class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50"
						>Features</a
					>
					<a
						href="/docs"
						class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50"
						>Documentation</a
					>
					<a
						href="/posts"
						class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50"
						>Blog</a
					>
					<a
						href="/publications"
						class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50"
						>Publications</a
					>
					<a
						href="/contributors"
						class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50"
						>Contributors</a
					>
				</div>
			</div>
		</nav>

		<main>
			<slot />
		</main>

		<footer class="bg-gray-50 border-t border-gray-200 mt-20">
			<div
				class="max-w-7xl mx-auto py-12 px-4 sm:px-6 flex flex-col items-center gap-8 lg:px-8"
			>
				<!-- Logos Section -->
				<div
					class="flex flex-col sm:flex-row justify-center items-center gap-8 sm:gap-16 opacity-80 filter grayscale hover:grayscale-0 transition-all duration-300"
				>
					<a
						href="https://www.unifi.it"
						target="_blank"
						rel="noopener noreferrer"
					>
						<img
							src={unifiLogo.src}
							alt="UniFi DINFO Logo"
							class="h-16 w-auto object-contain"
						/>
					</a>
					<a
						href="https://stlab.dinfo.unifi.it"
						target="_blank"
						rel="noopener noreferrer"
					>
						<img
							src={stlabLogo.src}
							alt="STLab Logo"
							class="h-14 w-auto object-contain"
						/>
					</a>
				</div>

				<div class="flex justify-center space-x-6">
					<a href="#" class="text-gray-400 hover:text-gray-500">
						<span class="sr-only">GitHub</span>
						<svg
							class="h-6 w-6"
							fill="currentColor"
							viewBox="0 0 24 24"
							aria-hidden="true"
						>
							<path
								fill-rule="evenodd"
								d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
								clip-rule="evenodd"></path>
						</svg>
					</a>
				</div>
				<div class="mt-4">
					<p class="text-center text-base text-gray-400">
						&copy; {new Date().getFullYear()} SALLMA Project. Developed
						by <a
							href="https://stlab.dinfo.unifi.it"
							class="hover:text-indigo-500">STLab</a
						> at <a
							href="https://www.unifi.it"
							class="hover:text-indigo-500"
							>University of Florence</a
						>.
					</p>
				</div>
			</div>
		</footer>
		<script>
			// Simple mobile menu toggle
			const btn = document.querySelector(
				'button[aria-controls="mobile-menu"]',
			);
			const menu = document.getElementById("mobile-menu");

			if (btn && menu) {
				btn.addEventListener("click", () => {
					const expanded =
						btn.getAttribute("aria-expanded") === "true";
					btn.setAttribute("aria-expanded", String(!expanded));
					menu.classList.toggle("hidden");
				});
			}
		</script>
	</body>
</html>
