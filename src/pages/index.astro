---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
---

<Layout title="SALLMA - Multi-Agent System Architecture">
	<div class="relative overflow-hidden bg-white">
		<div class="mx-auto max-w-7xl">
			<div
				class="relative z-10 bg-white pb-8 sm:pb-16 md:pb-20 lg:w-full lg:max-w-2xl lg:pb-28 xl:pb-32"
			>
				<svg
					class="absolute inset-y-0 right-0 hidden h-full w-48 translate-x-1/2 transform text-white lg:block"
					fill="currentColor"
					viewBox="0 0 100 100"
					preserveAspectRatio="none"
					aria-hidden="true"
				>
					<polygon points="50,0 100,0 50,100 0,100"></polygon>
				</svg>

				<main
					class="mx-auto mt-10 max-w-7xl px-4 sm:mt-12 sm:px-6 md:mt-16 lg:mt-20 lg:px-8 xl:mt-28"
				>
					<div class="sm:text-center lg:text-left">
						<h1
							class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl"
						>
							<span class="block xl:inline"
								>Software Architecture for</span
							>
							<span class="block text-indigo-600 xl:inline"
								>LLM-Based Multi-Agent Systems</span
							>
						</h1>
						<p
							class="mt-3 text-base text-gray-500 sm:mx-auto sm:mt-5 sm:max-w-xl sm:text-lg md:mt-5 md:text-xl lg:mx-0"
						>
							Build and automate cognitive workflows using a
							specific multi-agent collaborative system framework.
							SALLMA empowers you to orchestrate agents for
							complex tasks.
						</p>
						<div
							class="mt-5 sm:mt-8 sm:flex sm:justify-center lg:justify-start"
						>
							<div class="rounded-md shadow">
								<!-- FIXME: repo is private -->
								<a
									href="https://github.com/STLab-UniFI/SALLMA"
									class="flex w-full items-center justify-center rounded-md border border-transparent bg-indigo-600 px-8 py-3 text-base font-medium text-white hover:bg-indigo-700 md:py-4 md:text-lg md:px-10"
								>
									Download Software
								</a>
							</div>
							<div class="mt-3 sm:mt-0 sm:ml-3">
								<a
									href="/docs"
									class="flex w-full items-center justify-center rounded-md border border-transparent bg-indigo-100 px-8 py-3 text-base font-medium text-indigo-700 hover:bg-indigo-200 md:py-4 md:text-lg md:px-10"
								>
									Read Documentation
								</a>
							</div>
						</div>
					</div>
				</main>
			</div>
		</div>
		<div
			class="lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2 bg-indigo-50 flex items-center justify-center"
		>
			<!-- Abstract visualization or Hero Image placeholder -->
			<div class="p-8 text-center text-indigo-200">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					class="h-64 w-64 mx-auto text-indigo-400"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="1"
						d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
					></path>
				</svg>
				<p class="mt-4 font-mono text-xl text-indigo-500">
					SALLMA Architecture
				</p>
			</div>
		</div>
	</div>

	<div id="features" class="bg-gray-50 py-12 sm:py-24">
		<div class="mx-auto max-w-7xl px-6 lg:px-8">
			<div class="mx-auto max-w-2xl lg:text-center">
				<h2 class="text-base font-semibold leading-7 text-indigo-600">
					Why SALLMA?
				</h2>
				<p
					class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl"
				>
					Architecture for the Future of LLM Systems
				</p>
				<p class="mt-6 text-lg leading-8 text-gray-600">
					SALLMA addresses the challenges of single-agent systems like
					lack of task customization, memory, and flexibility.
				</p>
			</div>
			<div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-4xl">
				<dl
					class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-2 lg:gap-y-16"
				>
					<div class="relative pl-16">
						<dt
							class="text-base font-semibold leading-7 text-gray-900"
						>
							<div
								class="absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600"
							>
								<svg
									class="h-6 w-6 text-white"
									fill="none"
									viewBox="0 0 24 24"
									stroke-width="1.5"
									stroke="currentColor"
									aria-hidden="true"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"
									></path>
								</svg>
							</div>
							Operational Layer
						</dt>
						<dd class="mt-2 text-base leading-7 text-gray-600">
							Handles request intent management, real-time task
							execution, and dynamic orchestration of agents.
						</dd>
					</div>
					<div class="relative pl-16">
						<dt
							class="text-base font-semibold leading-7 text-gray-900"
						>
							<div
								class="absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600"
							>
								<svg
									class="h-6 w-6 text-white"
									fill="none"
									viewBox="0 0 24 24"
									stroke-width="1.5"
									stroke="currentColor"
									aria-hidden="true"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"
									></path>
								</svg>
							</div>
							Knowledge Layer
						</dt>
						<dd class="mt-2 text-base leading-7 text-gray-600">
							Stores and manages metamodels and configurations for
							workflows and agents.
						</dd>
					</div>
					<div class="relative pl-16">
						<dt
							class="text-base font-semibold leading-7 text-gray-900"
						>
							<div
								class="absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600"
							>
								<svg
									class="h-6 w-6 text-white"
									fill="none"
									viewBox="0 0 24 24"
									stroke-width="1.5"
									stroke="currentColor"
									aria-hidden="true"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"
									></path>
								</svg>
							</div>
							Modern Tech Stack
						</dt>
						<dd class="mt-2 text-base leading-7 text-gray-600">
							Built with Docker, Kubernetes, Python, LangChain,
							Hugging Face, Mistral, LLaMA, and more.
						</dd>
					</div>
				</dl>
			</div>
		</div>
	</div>

	<!-- About Section -->
	<div class="bg-white py-12 sm:py-24">
		<div class="mx-auto max-w-7xl px-6 lg:px-8">
			<div class="mx-auto max-w-2xl lg:mx-0">
				<h2
					class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl"
				>
					About The Project
				</h2>
				<p class="mt-6 text-lg leading-8 text-gray-600">
					SALLMA is a response to the paradigm shift in software
					engineering introduced by Large Language Models. It enables
					the creation of specialized agents that collaborate to solve
					complex, real-world problems.
				</p>
				<div
					class="mt-10 max-w-xl text-base leading-7 text-gray-700 space-y-4"
				>
					<p>
						Software architectures based on a single LLM agent face
						inherent challenges, such as lack of task customization,
						lack of memory, and limited access to ground truth.
						These challenges become especially pressing in
						real-world contexts.
					</p>
					<p>
						Currently, SALLMA is deployed to provide information on
						behalf of public administration offices and is utilized
						in business simulation scenarios.
					</p>
				</div>
			</div>
		</div>
	</div>
</Layout>
