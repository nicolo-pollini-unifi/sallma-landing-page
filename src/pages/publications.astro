---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Publications - SALLMA">
	<div class="bg-gray-50 pt-24 pb-12 sm:pt-32 sm:pb-16 lg:pb-24">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
					Publications
				</h2>
				<p class="mt-4 text-lg text-gray-500">
					Selected academic publications and technical reports related
					to the SALLMA project.
				</p>
			</div>
			<div class="mt-12 max-w-5xl mx-auto">
				<div class="bg-white shadow overflow-hidden sm:rounded-lg">
					<div class="px-4 py-5 sm:px-6">
						<h3 class="text-lg leading-6 font-medium text-gray-900">
							List of Publications
						</h3>
						<p class="mt-1 max-w-2xl text-sm text-gray-500">
							Ordered by date (newest first).
						</p>
					</div>
					<div class="border-t border-gray-200">
						<ol
							class="divide-y divide-gray-200 list-decimal list-outside px-6 py-4 space-y-4"
						>
							<li class="pl-2 text-gray-700">
								<span class="font-semibold text-gray-900"
									>Doe, J., Smith, A., & Johnson, B. (2025).</span
								>
								"Architecture for Large-Scale Multi-Agent Systems
								in Edge Computing."
								<span class="italic"
									>Journal of Software Systems</span
								>, 45(3), 112-128.
							</li>
							<li class="pl-2 text-gray-700">
								<span class="font-semibold text-gray-900"
									>Rossi, M., & Bianchi, L. (2025).</span
								>
								"LLM-driven Orchestration: A Case Study."
								<span class="italic"
									>Proceedings of the International Conference
									on AI Engineering (ICAI)</span
								>.
							</li>
							<li class="pl-2 text-gray-700">
								<span class="font-semibold text-gray-900"
									>Zhang, Y., & Chen, X. (2024).</span
								>
								"Self-Adaptive LLM Agents: Patterns and Practices."
								<span class="italic"
									>IEEE Transactions on Artificial
									Intelligence</span
								>.
							</li>
							<li class="pl-2 text-gray-700">
								<span class="font-semibold text-gray-900"
									>Smith, A. (2024).</span
								>
								"Scalable Microservices for Agentic Workflows."
								<span class="italic"
									>Tech Report STLab-2024-001</span
								>, University of Florence.
							</li>
							<li class="pl-2 text-gray-700">
								<span class="font-semibold text-gray-900"
									>Brown, C., & Davis, R. (2024).</span
								>
								"Evaluating Robustness in SALLMA-based Applications."
								<span class="italic"
									>Workshop on Generative AI Reliability</span
								>.
							</li>
							<li class="pl-2 text-gray-700">
								<span class="font-semibold text-gray-900"
									>Verdi, G., & Nero, P. (2023).</span
								>
								"Initial Design Patterns for LLM Coordination."
								<span class="italic"
									>arXiv preprint arXiv:2301.12345</span
								>.
							</li>
						</ol>
					</div>
				</div>
			</div>
		</div>
	</div>
</Layout>
