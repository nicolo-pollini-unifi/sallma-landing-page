---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contributors - SALLMA">
	<div class="bg-gray-50 min-h-screen pt-24 pb-12">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<!-- Header -->
			<div class="text-center mb-16">
				<h2
					class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl"
				>
					Meet the Team
				</h2>
				<p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
					The dedicated researchers and engineers behind the SALLMA
					project.
				</p>
			</div>

			<!-- Core Contributors Grid (3x2) -->
			<div
				class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-3 max-w-6xl mx-auto"
			>
				<!-- Contributor 1 -->
				<div
					class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden"
				>
					<div
						class="aspect-w-16 aspect-h-9 bg-indigo-600 h-32 relative"
					>
						<div
							class="absolute -bottom-12 left-1/2 transform -translate-x-1/2"
						>
							<img
								class="h-24 w-24 rounded-full border-4 border-white bg-gray-200"
								src="https://ui-avatars.com/api/?name=Enrico+Vicario&background=random"
								alt="Enrico Vicario, PhD"
							/>
						</div>
					</div>
					<div class="pt-16 pb-8 px-6 text-center">
						<h3 class="text-lg font-bold text-gray-900">
							Enrico Vicario, PhD
						</h3>
						<p class="text-indigo-600 font-medium text-sm">
							Lead Professor & Project Supervisor
						</p>
						<p class="mt-4 text-gray-500 text-sm">
							Provides strategic guidance and high-level
							oversight, leveraging decades of expertise in
							software engineering.
						</p>
					</div>
				</div>

				<!-- Contributor 2 -->
				<div
					class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden"
				>
					<div
						class="aspect-w-16 aspect-h-9 bg-emerald-600 h-32 relative"
					>
						<div
							class="absolute -bottom-12 left-1/2 transform -translate-x-1/2"
						>
							<img
								class="h-24 w-24 rounded-full border-4 border-white bg-gray-200"
								src="https://ui-avatars.com/api/?name=Marco+Becattini&background=random"
								alt="Marco Becattini, PhD"
							/>
						</div>
					</div>
					<div class="pt-16 pb-8 px-6 text-center">
						<h3 class="text-lg font-bold text-gray-900">
							Marco Becattini, PhD
						</h3>
						<p class="text-indigo-600 font-medium text-sm">
							Lead Researcher & Core Architect
						</p>
						<p class="mt-4 text-gray-500 text-sm">
							The original creator of the project; specializes in
							AI-driven multi-agent systems and coordination logic
							for autonomous LLM workflows.
						</p>
					</div>
				</div>

				<!-- Contributor 3 -->
				<div
					class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden"
				>
					<div
						class="aspect-w-16 aspect-h-9 bg-purple-600 h-32 relative"
					>
						<div
							class="absolute -bottom-12 left-1/2 transform -translate-x-1/2"
						>
							<img
								class="h-24 w-24 rounded-full border-4 border-white bg-gray-200"
								src="https://ui-avatars.com/api/?name=Leonardo+Scommegna&background=random"
								alt="Leonardo Scommegna, PhD"
							/>
						</div>
					</div>
					<div class="pt-16 pb-8 px-6 text-center">
						<h3 class="text-lg font-bold text-gray-900">
							Leonardo Scommegna, PhD
						</h3>
						<p class="text-indigo-600 font-medium text-sm">
							Senior Researcher & Collaborator
						</p>
						<p class="mt-4 text-gray-500 text-sm">
							Expert in cross-system integration; provides
							critical insights on bridging the platform with
							external technologies and software from our lab.
						</p>
					</div>
				</div>

				<!-- Contributor 4 -->
				<div
					class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden"
				>
					<div
						class="aspect-w-16 aspect-h-9 bg-blue-500 h-32 relative"
					>
						<div
							class="absolute -bottom-12 left-1/2 transform -translate-x-1/2"
						>
							<img
								class="h-24 w-24 rounded-full border-4 border-white bg-gray-200"
								src="https://ui-avatars.com/api/?name=Nicolò+Pollini&background=random"
								alt="Nicolò Pollini"
							/>
						</div>
					</div>
					<div class="pt-16 pb-8 px-6 text-center">
						<h3 class="text-lg font-bold text-gray-900">
							Nicolò Pollini
						</h3>
						<p class="text-indigo-600 font-medium text-sm">
							Junior Researcher & Software Engineer
						</p>
						<p class="mt-4 text-gray-500 text-sm">
							Co-directs the project and development team; leads
							the architectural redesign of the framework towards
							a true-agentic system.
						</p>
					</div>
				</div>

				<!-- Contributor 5 -->
				<div
					class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden"
				>
					<div
						class="aspect-w-16 aspect-h-9 bg-orange-500 h-32 relative"
					>
						<div
							class="absolute -bottom-12 left-1/2 transform -translate-x-1/2"
						>
							<img
								class="h-24 w-24 rounded-full border-4 border-white bg-gray-200"
								src="https://ui-avatars.com/api/?name=Niccolò+Caselli&background=random"
								alt="Niccolò Caselli"
							/>
						</div>
					</div>
					<div class="pt-16 pb-8 px-6 text-center">
						<h3 class="text-lg font-bold text-gray-900">
							Niccolò Caselli
						</h3>
						<p class="text-indigo-600 font-medium text-sm">
							Software Engineer
						</p>
						<p class="mt-4 text-gray-500 text-sm">
							Major contributor of the project; engineered the
							transition from the initial Python prototype to the
							current structured Java implementation.
						</p>
					</div>
				</div>

				<!-- Contributor 6 -->
				<div
					class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden"
				>
					<div
						class="aspect-w-16 aspect-h-9 bg-pink-600 h-32 relative"
					>
						<div
							class="absolute -bottom-12 left-1/2 transform -translate-x-1/2"
						>
							<img
								class="h-24 w-24 rounded-full border-4 border-white bg-gray-200"
								src="https://ui-avatars.com/api/?name=Matteo+Minin&background=random"
								alt="Matteo Minin"
							/>
						</div>
					</div>
					<div class="pt-16 pb-8 px-6 text-center">
						<h3 class="text-lg font-bold text-gray-900">
							Matteo Minin
						</h3>
						<p class="text-indigo-600 font-medium text-sm">
							AI Software Engineer
						</p>
						<p class="mt-4 text-gray-500 text-sm">
							Expert in integrating AI tooling into software
							pipelines; currently drives the development and
							optimization of core agent functionalities.
						</p>
					</div>
				</div>
			</div>

			<!-- Other Contributors Section -->
			<div class="mt-20 max-w-4xl mx-auto">
				<div
					class="bg-white rounded-lg shadow-sm border border-gray-100 p-8"
				>
					<h3
						class="text-center text-xl font-bold text-gray-900 mb-6"
					>
						Other Contributors
					</h3>
					<div class="flex flex-wrap justify-center gap-4">
						<span
							class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800"
						>
							Simone Mattolini
						</span>
						<span
							class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800"
						>
							Alessia Donati
						</span>
						<span
							class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800"
						>
							Silviu Leonard Vatamanelu
						</span>
						<span
							class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800"
						>
							Niccolò Menghini
						</span>
						<span
							class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800"
						>
							Filippo Sciammacca
						</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</Layout>
